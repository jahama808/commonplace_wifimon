# Top-level env for `docker compose up`. Copy to `.env` and edit as needed.
# Compose reads variables here automatically; the backend service maps them
# into the FastAPI / worker container env.

# Postgres
POSTGRES_USER=wifimon
POSTGRES_PASSWORD=wifimon
POSTGRES_DB=wifimon

# FastAPI session signing key — MUST be set in any non-toy deployment.
SECRET_KEY=change-me-in-prod

# eero API (server-side only — never reaches the browser)
EERO_API_TOKEN=

# Pushover (optional). If unset, the worker uses NullNotifier.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Public domain — used for the CORS allow-list on the FastAPI tier. Your
# host Caddy (or other reverse proxy) is responsible for actually routing
# this domain into the loopback-bound containers; see `Caddyfile.site`
# for the site block to drop into your existing Caddyfile.
DOMAIN=localhost

# Flip to `true` once you're serving over HTTPS so the session cookie gets
# the Secure flag. Don't enable on plain-HTTP localhost — browsers reject
# the cookie and login won't stick.
SESSION_COOKIE_SECURE=false
